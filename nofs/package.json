{
  "name": "nofs",
  "private": true,
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "server:dev": "pnpm --filter server run dev",
    "client:dev": "pnpm --filter client run dev",
    "typecheck": "turbo run typecheck",
    "typecheck:packages": "turbo run typecheck --filter=./packages",
    "db:test": "pnpm --filter @repo/db run db:test",
    "db:generate": "pnpm --filter @repo/db run db:generate",
    "db:push": "pnpm --filter @repo/db run db:push",
    "db:migrate": "pnpm --filter @repo/db run db:migrate",
    "db:studio": "pnpm --filter @repo/db run db:studio",
    "db:drop": "pnpm --filter @repo/db run db:drop",    
    "codegen": "turbo run codegen"
  },
  "devDependencies": {
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=18"
  }
}
