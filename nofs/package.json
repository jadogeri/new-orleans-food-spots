{
  "name": "nofs",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "server:dev": "pnpm --filter server run dev",
    "client:dev": "pnpm --filter client run dev",
    "typecheck": "turbo run typecheck",
    "typecheck:packages": "turbo run typecheck --filter=./packages",
    "db:test": "pnpm --filter @repo/db run db:test",
    "db:generate": "pnpm --filter @repo/db run db:generate",
    "db:push": "pnpm --filter @repo/db run db:push",
    "db:migrate": "pnpm --filter @repo/db run db:migrate",
    "db:studio": "pnpm --filter @repo/db run db:studio",
    "db:drop": "pnpm --filter @repo/db run db:drop",
    "db:clear": "pnpm --filter @repo/db run db:clear",
    "codegen": "turbo run codegen",
    "test:client": "pnpm --filter client run test",
    "test:server": "pnpm --filter server run test",
    "client:test:coverage": "pnpm --filter client run test:coverage",
    "server:test:coverage": "pnpm --filter server run test:coverage"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "linux",
        "win32"
      ],
      "cpu": [
        "current",
        "x64",
        "arm64"
      ]
    }
  }
}
