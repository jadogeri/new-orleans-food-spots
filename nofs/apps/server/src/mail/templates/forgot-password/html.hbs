<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Temporary Password</title>
</head>
<body style="margin:0;padding:0;background-color:#1a0f00;font-family:'Segoe UI',Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#1a0f00;padding:40px 20px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;">
          <!-- Header -->
          <tr>
            <td align="center" style="padding:0 0 32px 0;">
              <div style="font-size:28px;font-weight:700;color:#C9A84C;letter-spacing:2px;">🎷 NOLA Spots</div>
              <div style="height:2px;background:linear-gradient(90deg,transparent,#C9A84C,transparent);margin-top:12px;"></div>
            </td>
          </tr>
          <!-- Card -->
          <tr>
            <td style="background-color:#2a1a05;border-radius:12px;border:1px solid #3d2a0a;padding:40px 36px;">
              <h1 style="color:#C9A84C;font-size:22px;margin:0 0 16px 0;font-weight:700;">
                Password Recovery
              </h1>
              <p style="color:#f0e6d0;font-size:16px;line-height:1.7;margin:0 0 24px 0;">
                Hello{{#if firstName}} {{firstName}}{{/if}}, a temporary password has been generated for your account
                <strong style="color:#C9A84C;">{{email}}</strong>.
              </p>
              <!-- Temporary Password Box -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 28px 0;">
                <tr>
                  <td style="background-color:#1a0f00;border:2px solid #C9A84C;border-radius:8px;padding:20px;text-align:center;">
                    <p style="color:#a09070;font-size:12px;letter-spacing:1px;text-transform:uppercase;margin:0 0 8px 0;">Temporary Password</p>
                    <p style="color:#C9A84C;font-size:22px;font-weight:700;font-family:monospace;letter-spacing:3px;margin:0;">
                      {{temporaryPassword}}
                    </p>
                  </td>
                </tr>
              </table>
              <p style="color:#f0e6d0;font-size:15px;line-height:1.7;margin:0 0 20px 0;">
                Use this password to sign in, then go to <strong>Reset Password</strong> to set a new permanent password.
                This temporary password expires in <strong style="color:#C9A84C;">1 hour</strong>.
              </p>
              <div style="background-color:#3a1a00;border-left:3px solid #C9A84C;padding:14px 16px;border-radius:4px;margin:0 0 24px 0;">
                <p style="color:#f0e6d0;font-size:14px;margin:0;line-height:1.6;">
                  ⚠️ Do not share this password with anyone. Our support team will
                  <strong>never</strong> ask for your password.
                </p>
              </div>
              <p style="color:#a09070;font-size:14px;line-height:1.6;margin:0;">
                If you did not request a password recovery, contact us at
                <a href="mailto:{{supportEmail}}" style="color:#C9A84C;">{{supportEmail}}</a> immediately.
              </p>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td align="center" style="padding:28px 0 0 0;">
              <p style="color:#6b5230;font-size:13px;margin:0;">
                © {{year}} {{company}} · New Orleans, Louisiana
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
