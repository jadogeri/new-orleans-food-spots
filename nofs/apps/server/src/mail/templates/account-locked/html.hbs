<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Account Locked</title>
</head>
<body style="margin:0;padding:0;background-color:#1a0f00;font-family:'Segoe UI',Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#1a0f00;padding:40px 20px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;">
          <tr>
            <td align="center" style="padding:0 0 32px 0;">
              <div style="font-size:28px;font-weight:700;color:#C9A84C;letter-spacing:2px;">🎷 NOLA Spots</div>
              <div style="height:2px;background:linear-gradient(90deg,transparent,#C9A84C,transparent);margin-top:12px;"></div>
            </td>
          </tr>
          <tr>
            <td style="background-color:#2a1a05;border-radius:12px;border:1px solid #3d2a0a;padding:40px 36px;">
              <div style="text-align:center;margin-bottom:24px;">
                <span style="font-size:48px;">🔒</span>
              </div>
              <h1 style="color:#e05c5c;font-size:22px;margin:0 0 16px 0;font-weight:700;text-align:center;">
                Account Temporarily Locked
              </h1>
              <p style="color:#f0e6d0;font-size:16px;line-height:1.7;margin:0 0 20px 0;">
                Hello{{#if firstName}} {{firstName}}{{/if}}, we detected 3 consecutive failed login attempts on
                <strong style="color:#C9A84C;">{{email}}</strong>.
                For your security, this account has been temporarily locked for <strong>30 minutes</strong>.
              </p>
              <div style="background-color:#3a1a00;border-left:3px solid #e05c5c;padding:14px 16px;border-radius:4px;margin:0 0 24px 0;">
                <p style="color:#f0e6d0;font-size:14px;margin:0;line-height:1.6;">
                  ⚠️ If this was not you, reset your password immediately using the link below.
                </p>
              </div>
              <p style="color:#f0e6d0;font-size:15px;line-height:1.7;margin:0 0 24px 0;">
                To unlock your account sooner, use the <strong>Forgot Password</strong> option on the sign-in page to receive a temporary password.
              </p>
              <table cellpadding="0" cellspacing="0" style="margin:0 auto;">
                <tr>
                  <td style="background-color:#C9A84C;border-radius:6px;padding:14px 28px;">
                    <a href="{{logoUrl}}" style="color:#1a0f00;font-weight:700;font-size:15px;text-decoration:none;display:block;">
                      Recover My Account →
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td align="center" style="padding:28px 0 0 0;">
              <p style="color:#6b5230;font-size:13px;margin:0;">
                © {{year}} {{company}} · New Orleans, Louisiana
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
