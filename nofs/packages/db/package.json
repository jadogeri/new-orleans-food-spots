{
  "name": "@repo/db",
  "author": "Joseph Adogeri",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "node -e \"import('fs').then(fs => fs.existsSync('tsconfig.tsbuildinfo') && fs.unlinkSync('tsconfig.tsbuildinfo'))\"",
    "build": "tsc",
    "dev": "tsc --watch",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate --config=drizzle.config.ts",
    "db:push": "tsx node_modules/drizzle-kit/bin.cjs push --config=drizzle.config.ts",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate --config=drizzle.config.ts",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio --config=drizzle.config.ts",
    "db:drop": "tsx node_modules/drizzle-kit/bin.cjs drop --config=drizzle.config.ts",
    "db:clear": "tsx src/clear-db.ts",
    "db:test": "tsx src/test-db.ts",
    "pnpm:approve-builds": "pnpm approve-builds"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "catalog:",
    "drizzle-seed": "^0.3.1",
    "drizzle-zod": "^0.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "drizzle-kit": "^0.30.5",
    "tsx": "catalog:"
  }
}
