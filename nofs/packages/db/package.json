{
  "name": "@repo/db",
  "author": "Joseph Adogeri",
  "version": "0.0.0",
  "private": true,
  "type": "module", 
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "node -e \"import('fs').then(fs => fs.existsSync('tsconfig.tsbuildinfo') && fs.unlinkSync('tsconfig.tsbuildinfo'))\"",
    "build": "tsc",
    "dev": "tsc --watch",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "test": "tsx src/test-db.ts",
    "pnpm:approve-builds":"pnpm approve-builds"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:", 
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.30.5",
    "tsx": "catalog:",
    "typescript": "^5.0.0"
  }
}
