{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",         // 💡 FIXED: Forces the compiler to output files into the /dist folder
    "rootDir": "./src",         // 💡 FIXED: Tells the compiler to look only inside /src
    "declaration": true,        // 💡 Generates type files (.d.ts)
    "declarationMap": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
