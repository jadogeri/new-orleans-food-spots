# Database Settings
TURSO_DATABASE_URL=your_Turso_database_URL_here
TURSO_AUTH_TOKEN=your_NEW_invalidated_turso_token_here

# App Secrets
SESSION_SECRET=a_long_random_super_secret_string_here
YELP_API_KEY=Yelp API key goes here

# Core Routing Configuration (Matched to your current state)
CLIENT_PORT=4000
SERVER_PORT=3000
BASE_PATH=/

# Auth & API URLs (Pointing to your NestJS Backend)
FRONTEND_URL=http://localhost:4000
BACKEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000/api/auth

DATABASE_URL=file:local.db

# Mail Configuration
GMAIL_USER=your gmail address here
GMAIL_APP_PASSWORD=your gmail app password here

# Optional: Customize the visible sender name and email address
MAIL_FROM='"NOLA Spots" <your-email@gmail.com>'

NODE_ENV=your environment here (development or production)

BREVO_API_KEY=your Brevo API key here
BREVO_SENDER_EMAIL=your Brevo sender email here