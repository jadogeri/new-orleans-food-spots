    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- NOTES                                                       -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <mxCell id="80" value="Notes:&#xa;• Database engine: LibSQL (SQLite dialect) hosted on Turso&#xa;• All TEXT date fields store ISO-8601 strings (Better Auth convention)&#xa;• ON DELETE CASCADE propagates user deletion to all child rows&#xa;• emailVerified stored as INTEGER (0/1) — SQLite has no native BOOLEAN&#xa;• UNIQUE(userId, yelpId) prevents duplicate bookmarks per user" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontSize=11;fillColor=#f5f5f5;strokeColor=#999;fontColor=#333;" vertex="1" parent="1">
      <mxGeometry x="960" y="480" width="480" height="110" as="geometry" />
    </mxCell>

